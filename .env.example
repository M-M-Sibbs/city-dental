# =============================================================
# City Dental — environment variables
# Booking & contact form submissions are emailed to the clinic.
# Set ONE of the two providers below in Vercel → Settings → Environment Variables.
# =============================================================

# Where booking + contact emails are delivered (already defaults to this):
BOOKING_INBOX=butetemunyaradzi@gmail.com

# Your live domain, used for canonical URLs, sitemap & structured data:
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---- OPTION A: Resend (recommended, easiest on Vercel) ----
# 1. Create a free account at https://resend.com
# 2. Create an API key and paste it here.
# 3. (Optional) verify a domain and set MAIL_FROM to an address on it.
#    Until then you can use the shared onboarding sender.
RESEND_API_KEY=
MAIL_FROM=City Dental <onboarding@resend.dev>

# ---- OPTION B: Gmail SMTP (send straight from a Gmail account) ----
# 1. Turn on 2-Step Verification on the Gmail account.
# 2. Create an "App Password" (Google Account → Security → App passwords).
# 3. Put the Gmail address in GMAIL_USER and the 16-char app password in GMAIL_APP_PASSWORD.
#    NOTE: use an App Password, NOT your normal Gmail password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
